# ---- Postgres ----
POSTGRES_USER=fitness
POSTGRES_PASSWORD=fitness
POSTGRES_DB=fitness

# ---- Backend ----
# Full connection string used by the Go API (and migrate).
# For local docker-compose the host is the service name "db".
DATABASE_URL=postgres://fitness:fitness@db:5432/fitness?sslmode=disable
# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=dev-change-me-to-a-long-random-string
# How long an access token is valid (hours).
JWT_TTL_HOURS=720
# Port the API listens on.
PORT=8080
# Comma-separated list of allowed CORS origins (the frontend URL).
CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
# Base URL the browser uses to reach the API. Must be reachable from the device.
NEXT_PUBLIC_API_URL=http://localhost:8080
